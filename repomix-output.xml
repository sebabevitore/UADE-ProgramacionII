    public V value() {
        return value;
    }

    public void setValue(V value) {
        this.value = value;
    }

    public NodeSimpleDict<K, V> next() {
        return next;
    }

    public void setNext(NodeSimpleDict<K, V> next) {
        this.next = next;
    }
